# --- Dependencies & package managers ---
node_modules/
.pnpm-store/
*.tgz

# --- Build outputs & caches ---
.turbo/
dist/
build/
.next/
out/
*.tsbuildinfo
coverage/

# --- Expo / React Native ---
# Native projects are generated by `npx expo run:*` (CNG) — regenerable, not source.
.expo/
apps/mobile/android/
apps/mobile/ios/
web-build/
# Signing material must never be committed
*.jks
*.keystore
*.p8
*.p12
*.mobileprovision

# --- Environment & secrets (commit only .env.example) ---
.env
.env.*
!.env.example

# --- Test artifacts (generated per-run by scripts/e2e-*.sh — never committed) ---
test-results/
*.xcresult

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Local databases ---
*.db
*.db-journal
*.sqlite

# --- IDE & tooling ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
# .claude/agents/ is tracked: generated by scripts/render-agents.mjs, needed at runtime by Claude Code
.claude/settings.local.json

# --- OS noise ---
.DS_Store
Thumbs.db
