<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only manifest merge: points the app at the debug network security
     config so cleartext HTTP to the local dev API is allowed only in debug
     builds (see src/debug/res/xml/network_security_config.xml). -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
