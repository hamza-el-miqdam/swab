# Public (bundled) configuration only — never put secrets here (G1).
# iOS simulator / web: http://localhost:3001 (API default port, see apps/api).
# Android emulator: use http://10.0.2.2:3001 — the emulator's alias for the
# host machine's localhost (see ANDROID_SETUP.md step 5).
EXPO_PUBLIC_API_URL=http://localhost:3001
# Salt for client-side phone hashing (IDT-01/IDT-06). Shared across clients of
# one deployment by design — it is a namespace, not a secret.
EXPO_PUBLIC_PHONE_HASH_SALT=change-me-per-environment
