    "base": { "family": "Inter", "size": 15, "weight": 400, "lineHeight": 1.6, "letterSpacing": 0, "textTransform": "none" },
    "button": { "family": "Inter", "size": 15, "weight": 500, "lineHeight": 1.2, "letterSpacing": 0, "textTransform": "none" },
    "subtitle": { "family": "Inter", "size": 13.5, "weight": 400, "lineHeight": 1.5, "letterSpacing": 0, "textTransform": "none" },
    "tag": { "family": "Inter", "size": 14, "weight": 400, "lineHeight": 1.3, "letterSpacing": 0, "textTransform": "none" },
    "caption": { "family": "Inter", "size": 12, "weight": 400, "lineHeight": 1.5, "letterSpacing": 0, "textTransform": "none" },
