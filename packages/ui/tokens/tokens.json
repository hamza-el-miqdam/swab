{
  "meta": {
    "name": "Swab Design Tokens — Nuit",
    "description": "Canonical, hand-edited, machine-readable export of the Nuit token set. Single source of truth for every generated consumer format (TS/CSS/Swift/Kotlin) produced by packages/ui/scripts/generate.mjs.",
    "source": "Penpot 'Swab — Design System' page, token set 'Nuit' (pulled via the Penpot MCP plugin), cross-checked against docs/design-system.md §1-4 — both agree as of 2026-07-19.",
    "rule": "Do NOT hand-invent values here. Per agents/design-specialist.md's Definition of Done, any new/changed value must land in the prototype (docs/design/swab-prototype-consolidated.html) and docs/design-system.md first, then propagate into this file, then be regenerated. This file is downstream of that chain, never a bypass of it.",
    "lastUpdated": "2026-07-19"
  },
  "color": {
    "nuit": { "value": "#0f1426", "role": "App background (deepest surface)." },
    "encre": { "value": "#171e38", "role": "Screen / primary card surface." },
    "voile": { "value": "#202949", "role": "Raised surface — tags, tiles, list rows, inputs." },
    "voile-2": { "value": "#28325a", "role": "Higher surface — avatars, switch track (off)." },
    "hair": { "value": "#edebe2", "opacity": 0.12, "role": "Hairline separators & default borders." },
    "hair-fort": { "value": "#edebe2", "opacity": 0.22, "role": "Stronger border — interactive outlines, ghost buttons." },
    "ivoire": { "value": "#edebe2", "role": "Primary text / high-emphasis." },
    "brume": { "value": "#9aa1c2", "role": "Secondary text — subtitles, descriptions." },
    "ombre": { "value": "#6a7194", "role": "Tertiary text — labels, meta, muted values." },
    "etoile": { "value": "#e4be6a", "role": "Primary accent — primary button, selected state, links, eyebrow." },
    "etoile-encre": { "value": "#1c1505", "role": "Ink on étoile (text/icon over the gold button)." },
    "sauge": { "value": "#6fbfa3", "role": "Positive / révélé — reciprocal link revealed, success." },
    "ciel": { "value": "#84a9e6", "role": "Informational / neutral node accent." },
    "corail": { "value": "#d98a73", "role": "Caution / en retrait — absolute-lock presence state. Never 'error red'." }
  },
  "typography": {
